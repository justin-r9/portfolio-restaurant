---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="Our Story - The Native Grill">
  <Header />
  
  <main class="flex-grow pt-16">
    <!-- Page Header -->
    <section class="relative h-[353px] min-h-[300px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="/images/spices_1779117880508.png" alt="A moody, top-down shot of vibrant spices" class="w-full h-full object-cover opacity-50" />
        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/80 to-transparent"></div>
      </div>
      <div class="relative z-10 text-center px-margin-mobile">
        <h1 class="font-display-lg-mobile md:font-display-lg text-[40px] md:text-[64px] text-on-surface mb-4">Our Story</h1>
        <p class="font-body-lg text-[18px] text-on-surface-variant max-w-2xl mx-auto">From the bustling streets to the refined plate.</p>
      </div>
    </section>

    <!-- Narrative Section -->
    <section class="py-24 bg-background border-b border-on-surface/10">
      <div class="max-w-[800px] mx-auto px-margin-mobile text-center">
        <span class="material-symbols-outlined text-[48px] text-primary-container mb-8">local_fire_department</span>
        <h2 class="font-headline-lg text-[32px] text-on-surface mb-8">The spark that started it all.</h2>
        <div class="font-body-md text-[16px] text-on-surface-variant space-y-6 leading-relaxed">
          <p>The Native Grill was born out of a profound respect for the Mai Suya—the unsung culinary artists of Nigeria's streets. Their mastery of smoke, spice, and fire is an intricate dance that produces flavors unlike any other.</p>
          <p>We wanted to take that visceral, deeply nostalgic experience and place it in an environment that honors its complexity. No shortcuts. Just premium ingredients, ancestral recipes passed down through generations, and the transformative power of hardwood embers.</p>
        </div>
      </div>
    </section>

    <!-- Visual Narrative (Masonry-ish) -->
    <section class="py-24 bg-surface">
      <div class="max-w-container-max-width mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-gutter">
        
        <!-- Large Image -->
        <div class="col-span-1 md:col-span-7 aspect-[4/3] rounded-xl overflow-hidden border border-on-surface/10 relative">
          <img src="/images/chef_story_1779117862878.png" alt="Chef plating" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-background/60 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8">
            <h3 class="font-headline-md text-[24px] text-on-surface">Meticulous Craft</h3>
            <p class="font-body-md text-[16px] text-on-surface-variant">Every plate is a canvas.</p>
          </div>
        </div>

        <!-- Right Column (Text + Small Image) -->
        <div class="col-span-1 md:col-span-5 flex flex-col gap-8">
          <div class="bg-surface-container rounded-xl p-8 border border-on-surface/10 flex-grow flex flex-col justify-center">
            <p class="font-headline-md text-[24px] text-on-surface italic mb-4">"We don't just cook food; we curate memories heavily spiced with nostalgia."</p>
            <p class="font-label-sm text-[12px] text-primary-container uppercase tracking-wider">— Head Chef, Tunde A.</p>
          </div>
          <div class="aspect-video rounded-xl overflow-hidden border border-on-surface/10 relative group">
             <img src="/images/spices_1779117880508.png" alt="Spice blend" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
             <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-background/20 to-transparent"></div>
             <div class="absolute bottom-0 left-0 p-6">
                <p class="font-body-md text-[14px] md:text-[16px] text-on-surface-variant leading-tight">Our signature Yaji spice blend is crafted in-house daily, toasting 14 individual spices over open embers.</p>
             </div>
          </div>
        </div>

      </div>
    </section>
    <!-- Reservation CTA -->
    <section class="py-24 bg-surface-container border-t border-on-surface/10 text-center px-margin-mobile md:px-margin-desktop">
      <div class="max-w-2xl mx-auto flex flex-col items-center">
        <h2 class="font-headline-lg text-[32px] md:text-[40px] text-on-surface mb-6">Be Part of the Story</h2>
        <p class="font-body-md text-[16px] md:text-[18px] text-on-surface-variant mb-10">
          We invite you to join us and experience the culmination of our craft firsthand.
        </p>
        <a href="/contact" class="bg-primary-container text-on-primary-container px-10 py-4 rounded font-label-sm text-[14px] uppercase tracking-widest hover:bg-inverse-primary transition-colors active:scale-95 shadow-[0_20px_40px_rgba(0,0,0,0.5)] inline-block">
          Make a Reservation
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</MainLayout>
