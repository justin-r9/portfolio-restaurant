---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="Reservations - The Native Grill">
  <Header />
  
  <main class="flex-grow pt-16">
    <div class="max-w-container-max-width mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-24 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      
      <!-- Form Section -->
      <section>
        <div class="mb-12">
          <h1 class="font-display-lg-mobile md:font-display-lg text-[40px] md:text-[64px] text-on-surface mb-4">Reservations</h1>
          <p class="font-body-lg text-[18px] text-on-surface-variant">Secure your table for an unforgettable culinary journey.</p>
        </div>

        <form class="space-y-6" action="#" method="POST" onsubmit="event.preventDefault(); alert('Reservation request submitted!');">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="date" class="font-label-sm text-[12px] text-on-surface-variant uppercase tracking-wider">Date</label>
              <input type="date" id="date" name="date" class="bg-surface border border-on-surface/20 rounded p-4 text-on-surface font-body-md text-[16px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors [&::-webkit-calendar-picker-indicator]:mr-2 [&::-webkit-calendar-picker-indicator]:cursor-pointer" required>
            </div>
            <div class="flex flex-col gap-2">
              <label for="time" class="font-label-sm text-[12px] text-on-surface-variant uppercase tracking-wider">Time</label>
              <select id="time" name="time" class="bg-surface border border-on-surface/20 rounded p-4 text-on-surface font-body-md text-[16px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors appearance-none" required>
                <option value="">Select a time</option>
                <option value="17:00">5:00 PM</option>
                <option value="18:00">6:00 PM</option>
                <option value="19:00">7:00 PM</option>
                <option value="20:00">8:00 PM</option>
                <option value="21:00">9:00 PM</option>
              </select>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="guests" class="font-label-sm text-[12px] text-on-surface-variant uppercase tracking-wider">Number of Guests</label>
            <select id="guests" name="guests" class="bg-surface border border-on-surface/20 rounded p-4 text-on-surface font-body-md text-[16px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors appearance-none" required>
              <option value="">Select party size</option>
              <option value="1">1 Person</option>
              <option value="2">2 People</option>
              <option value="3">3 People</option>
              <option value="4">4 People</option>
              <option value="5+">5+ People (Call us)</option>
            </select>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="name" class="font-label-sm text-[12px] text-on-surface-variant uppercase tracking-wider">Name</label>
              <input type="text" id="name" name="name" placeholder="Your full name" class="bg-surface border border-on-surface/20 rounded p-4 text-on-surface font-body-md text-[16px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors placeholder:text-on-surface/30" required>
            </div>
            <div class="flex flex-col gap-2">
              <label for="phone" class="font-label-sm text-[12px] text-on-surface-variant uppercase tracking-wider">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="e.g. +234..." class="bg-surface border border-on-surface/20 rounded p-4 text-on-surface font-body-md text-[16px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors placeholder:text-on-surface/30" required>
            </div>
          </div>
          
          <button type="submit" class="w-full bg-primary-container text-on-primary-container py-4 rounded font-label-sm text-[12px] uppercase tracking-widest hover:bg-inverse-primary transition-colors mt-4">
            Request Table
          </button>
        </form>
      </section>

      <!-- Contact Info & Map Section -->
      <section class="flex flex-col gap-12">
        <div class="bg-surface-container rounded-xl p-6 md:p-8 border border-on-surface/10">
          <h3 class="font-headline-md text-[24px] text-on-surface mb-6 border-b border-on-surface/10 pb-4">Direct Contact</h3>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary-container">location_on</span>
              <div>
                <p class="font-body-md text-[16px] text-on-surface font-semibold">Address</p>
                <p class="font-body-md text-[16px] text-on-surface-variant">15 Embers Way, Independence Layout<br/>Enugu, Nigeria</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary-container">call</span>
              <div>
                <p class="font-body-md text-[16px] text-on-surface font-semibold">Phone</p>
                <p class="font-body-md text-[16px] text-on-surface-variant">+234 (0) 800 NATIVE</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary-container">mail</span>
              <div>
                <p class="font-body-md text-[16px] text-on-surface font-semibold">Email</p>
                <p class="font-body-md text-[16px] text-on-surface-variant">reservations@thenativegrill.com</p>
              </div>
            </div>
          </div>
        </div>

        <div class="relative w-full aspect-video md:aspect-[4/3] rounded-xl overflow-hidden border border-on-surface/10 bg-surface-container group">
          <img src="/images/hero_bg_1779117776774.png" alt="Map Location" class="w-full h-full object-cover opacity-50 grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:opacity-80" />
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="bg-surface/90 backdrop-blur-md px-6 py-3 rounded-full border border-on-surface/10 flex items-center gap-2 shadow-[0_20px_40px_rgba(0,0,0,0.5)]">
              <span class="material-symbols-outlined text-primary-container">map</span>
              <span class="font-label-sm text-[12px] uppercase tracking-wider text-on-surface">View on Maps</span>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>
  
  <Footer />
</MainLayout>
